# Release signing credentials. Copy this file to `keystore.properties` (which is gitignored)
# and fill in your own values. The keystore itself (*.jks / *.keystore) is also gitignored —
# keep it private and reuse the SAME keystore for every release, or updates won't install over
# a previous version.
#
# Generate a keystore once with:
#   keytool -genkeypair -v -keystore release.jks -alias upload \
#           -keyalg RSA -keysize 2048 -validity 10000
#
# Then build a signed APK with:
#   ./gradlew :app:assembleRelease
#   # output: app/build/outputs/apk/release/app-release.apk

storeFile=release.jks
storePassword=CHANGEME
keyAlias=upload
keyPassword=CHANGEME
